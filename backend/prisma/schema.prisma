generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model System {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  icon        String
  link        String
  order       Int
  active      Boolean @default(true)
}

model Campaign {
  id      Int     @id @default(autoincrement())
  title   String
  text    String
  image   String
  order   Int
  active  Boolean @default(true)
}

model Activity {
  id        Int      @id @default(autoincrement())
  text      String
  time      String
  date      String
  createdAt DateTime @default(now())
}

model PageView {
  id        Int      @id @default(autoincrement())
  page      String
  createdAt DateTime @default(now())
}

model SystemClick {
  id         Int      @id @default(autoincrement())
  systemName String
  createdAt  DateTime @default(now())
}

model MediaImage {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  createdAt DateTime @default(now())
}

model WeeklyMenu {
  id        Int      @id @default(autoincrement())
  weekStart DateTime @unique
  active    Boolean  @default(true)

  segundaItems     String?
  segundaToDefine  Boolean @default(false)
  segundaHoliday   Boolean @default(false)

  tercaItems       String?
  tercaToDefine    Boolean @default(false)
  tercaHoliday     Boolean @default(false)

  quartaItems      String?
  quartaToDefine   Boolean @default(false)
  quartaHoliday    Boolean @default(false)

  quintaItems      String?
  quintaToDefine   Boolean @default(false)
  quintaHoliday    Boolean @default(false)

  sextaItems       String?
  sextaToDefine    Boolean @default(false)
  sextaHoliday     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Popup {
  id                Int      @id @default(autoincrement())
  title             String
  message           String
  active            Boolean  @default(true)
  showOnce          Boolean  @default(false)
  closeOnlyOnButton Boolean  @default(false)
  autoCloseSeconds  Int?
  displayType       String   @default("modal")
  position          String   @default("top-right")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}